{
  "name": "create-cherry-app",
  "version": "0.1.0",
  "description": "CLI generator for ready-to-use UMKM websites.",
  "type": "module",
  "bin": {
    "create-cherry-app": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --target node18 --clean",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "keywords": [
    "create",
    "starter",
    "nextjs",
    "umkm",
    "cli"
  ],
  "author": "Luqman Nur Hakim",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "chalk": "^5.4.1",
    "execa": "^9.5.2",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}