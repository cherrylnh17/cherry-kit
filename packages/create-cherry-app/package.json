{
  "name": "create-cherry-app",
  "version": "0.1.0",
  "description": "CLI untuk membuat starter kit Next.js UMKM.",
  "type": "module",
  "bin": {
    "create-cherry-app": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --target node18 --clean",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "chalk": "^5.4.1",
    "execa": "^9.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.20",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}