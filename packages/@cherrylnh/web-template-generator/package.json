{
  "name": "@cherrylnh/web-template-generator",
  "version": "0.1.0",
  "description": "JavaScript/TypeScript library untuk generate template halaman web dengan multi-bahasa support dan fitur 3D Three.js",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "locales",
    "templates"
  ],
  "scripts": {
    "build": "tsc && rollup -c",
    "dev": "tsc --watch",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "template",
    "generator",
    "web",
    "i18n",
    "multi-language",
    "html",
    "landing-page",
    "threejs",
    "3d",
    "webgl"
  ],
  "author": "Luqman Nur Hakim",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "rollup": "^4.0.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0"
  },
  "peerDependencies": {
    "typescript": ">=4.0.0"
  }
}